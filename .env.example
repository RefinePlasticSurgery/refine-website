VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
# WhatsApp Number (used in WhatsApp button for contact)
# Format: +countrycode-phonenumber
# Example: +255793145167
VITE_WHATSAPP_NUMBER="+255793145167"

# Environment setting (development, production)
DENO_ENV=production

# Optional: Sentry Error Tracking (for production error monitoring)
# Get your Sentry DSN from https://sentry.io/
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Optional: Google Analytics (if using Google Analytics)
# VITE_GA_ID=your-google-analytics-id

# Optional: Mixpanel Analytics (if using Mixpanel)
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Email Service Configuration (Resend)
# ⚠️ IMPORTANT: Set this in Supabase Edge Function secrets, NOT in .env
# How to set up:
#   1. Create account at https://resend.com
#   2. Copy your API key from Resend dashboard
#   3. Go to Supabase → Edge Functions → send-appointment-email → Secrets
#   4. Add secret: Name="RESEND_API_KEY", Value="your-api-key"
# For production: Verify your domain in Resend to use custom sender email
# For development: Use "onboarding@resend.dev" (Resend's test domain)
RESEND_API_KEY="your-resend-api-key"

# API Rate Limiting Configuration (for Edge Functions)
# Maximum number of requests allowed
RATE_LIMIT_MAX_REQUESTS=5
# Time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60